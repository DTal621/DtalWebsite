---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageSection from '../components/PageSection.astro';
import PostListItem from '../components/PostListItem.astro';
import { profile } from '../data/profile';

// Blog posts — sorted newest-first
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const articles = profile.articles;

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'short',
    year:  'numeric',
  });
}
---

<BaseLayout title={`Writing — ${profile.name}`}>
  <Nav />

  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-4 pt-20 pb-16">
    <h1 class="font-display text-4xl sm:text-5xl font-medium text-text tracking-tight leading-tight">
      Writing
    </h1>
    <p class="font-sans mt-4 text-lg text-muted max-w-2xl leading-relaxed">
      Blog posts and external writing on crypto, product, and whatever's on my mind.
    </p>
  </section>

  <!-- ── Blog ──────────────────────────────────────────────────────────── -->
  <PageSection heading="blog" first>
    {posts.length > 0 ? (
      <ul class="divide-y divide-border">
        {posts.map(post => (
          <PostListItem
            title={post.data.title}
            meta={post.data.publishDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
            url={`/blog/${post.id}`}
            summary={post.data.description}
          />
        ))}
      </ul>
    ) : (
      <p class="font-mono text-xs text-muted">no posts yet.</p>
    )}
  </PageSection>

  <!-- ── External writing ──────────────────────────────────────────────── -->
  <PageSection heading="external writing">
    {articles.length > 0 ? (
      <ul class="divide-y divide-border">
        {articles.map(article => (
          <PostListItem
            title={article.title}
            meta={`${article.platform} · ${formatDate(article.publishedAt)}`}
            url={article.url}
            summary={article.summary}
            external
          />
        ))}
      </ul>
    ) : (
      <p class="font-mono text-xs text-muted">no external articles yet.</p>
    )}
  </PageSection>

</BaseLayout>
