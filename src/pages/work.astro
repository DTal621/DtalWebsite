---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageSection from '../components/PageSection.astro';
import RoleCard from '../components/RoleCard.astro';
import { profile } from '../data/profile';
---

<BaseLayout title={`Work — ${profile.name}`}>
  <Nav />

  <!-- ── Hero (above fold — not animated) ─────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-4 pt-20 pb-16">
    <h1 class="font-display text-4xl sm:text-5xl font-medium text-text tracking-tight leading-tight">
      Work
    </h1>
    <p class="font-sans mt-4 text-lg text-muted max-w-2xl leading-relaxed">
      A record of the roles, products, and protocols I've built.
    </p>
  </section>

  <!-- ── Experience ────────────────────────────────────────────────────── -->
  <PageSection heading="experience" first>
    <div class="flex flex-col gap-5">
      {profile.roles.map((role, i) => (
        <div data-fade data-delay={i * 80}>
          <RoleCard role={role} />
        </div>
      ))}
    </div>
  </PageSection>

</BaseLayout>

<script>
  import { initFadeIn } from '../scripts/motion';
  initFadeIn();
</script>
