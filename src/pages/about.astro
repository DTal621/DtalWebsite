---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageSection from '../components/PageSection.astro';
import { profile } from '../data/profile';

const { about } = profile;

const ctaLinks = about.ctaLinkLabels
  .map(label => profile.links.find(l => l.label === label))
  .filter(Boolean);
---

<BaseLayout title={`About — ${profile.name}`}>
  <Nav />

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-4 pt-20 pb-12">
    <h1 class="font-display text-4xl sm:text-5xl font-medium text-text tracking-tight leading-tight">
      About
    </h1>
  </section>

  <!-- ── Intro prose ───────────────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-4 pb-16 border-t border-border pt-12">
    <div class="max-w-[65ch]">
      {about.intro.map(paragraph => (
        <p class="font-sans text-base leading-[1.75] text-text mb-5 last:mb-0">
          {paragraph}
        </p>
      ))}
    </div>
  </section>

  <!-- ── Currently exploring ───────────────────────────────────────────── -->
  <PageSection heading="currently exploring">
    <p class="font-sans text-base leading-[1.75] text-text max-w-[65ch]">
      {about.currentlyExploring}
    </p>
  </PageSection>

  <!-- ── Off the clock ─────────────────────────────────────────────────── -->
  <PageSection heading="off the clock">
    <p class="font-sans text-base leading-[1.75] text-text max-w-[65ch]">
      {about.offTheClock}
    </p>
  </PageSection>

  <!-- ── CTA ───────────────────────────────────────────────────────────── -->
  <PageSection heading={about.cta.heading}>
    <div class="bg-surface border border-border rounded-xl p-8 max-w-[65ch]">
      <p class="font-sans text-base leading-[1.75] text-text">
        {about.cta.body}
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        {ctaLinks.map(link => (
          <a
            href={link!.url}
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-border bg-bg font-mono text-xs lowercase tracking-wide text-text hover:text-accent hover:border-accent transition-colors"
          >
            {link!.label} →
          </a>
        ))}
      </div>
    </div>
  </PageSection>

</BaseLayout>
