---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import StatTile from '../components/StatTile.astro';
import CapabilityChip from '../components/CapabilityChip.astro';
import HobbyTile from '../components/HobbyTile.astro';
import { profile } from '../data/profile';
---

<BaseLayout title={profile.name}>
  <Nav />

  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-4 pt-20 pb-16">
    <h1 class="text-4xl sm:text-5xl font-bold text-brand-accent tracking-tight leading-tight">
      {profile.name}
    </h1>
    <p class="mt-4 text-lg sm:text-xl text-brand-muted max-w-2xl leading-relaxed">
      {profile.tagline}
    </p>
  </section>

  <!-- ── Stats ─────────────────────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-4 py-16 border-t border-brand-border">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-brand-muted mb-8">
      By the numbers
    </h2>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {profile.stats.map(stat => (
        <StatTile stat={stat} />
      ))}
    </div>
  </section>

  <!-- ── Capabilities ──────────────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-4 py-16 border-t border-brand-border">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-brand-muted mb-8">
      Skills
    </h2>
    <div class="flex flex-wrap gap-3">
      {profile.capabilities.map(cap => (
        <CapabilityChip capability={cap} />
      ))}
    </div>
  </section>

  <!-- ── Off-chain ──────────────────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-4 py-16 border-t border-brand-border">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-brand-muted mb-8">
      Off-chain
    </h2>
    <div class="grid grid-cols-3 sm:grid-cols-6 gap-4">
      {profile.hobbies.map(hobby => (
        <HobbyTile hobby={hobby} />
      ))}
    </div>
  </section>

</BaseLayout>
