---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <!-- ── Flash-free theme init ──────────────────────────────────────────
         Runs synchronously before first paint. Reads localStorage then
         falls back to system preference. Sets data-theme on <html> so
         CSS custom properties resolve to the correct palette immediately.
    ─────────────────────────────────────────────────────────────────────── -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = stored !== null ? stored : (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body class="bg-bg text-text font-sans antialiased min-h-screen">
    <slot />
  </body>
</html>
