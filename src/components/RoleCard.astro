---
import type { Role } from '../data/profile';

interface Props {
  role: Role;
}

const { role } = Astro.props;
---

<article class="bg-brand-surface rounded-2xl p-6 border border-brand-border">

  <!-- Title row: role title left, period right -->
  <div class="flex flex-wrap items-start justify-between gap-x-4 gap-y-1">
    <h3 class="text-base font-semibold text-brand-accent">
      {role.title}
    </h3>
    <span class="text-sm text-brand-muted shrink-0">
      {role.period}
    </span>
  </div>

  <!-- Org · location -->
  <p class="mt-1 text-sm text-brand-muted">
    {role.org} &middot; {role.location}
  </p>

  <!-- Achievements -->
  <ul class="mt-4 space-y-2">
    {role.achievements.map(a => (
      <li class="flex gap-2">
        <span class="mt-0.5 text-brand-muted select-none shrink-0" aria-hidden="true">·</span>
        <span class="text-sm text-brand-text leading-relaxed">{a.text}</span>
      </li>
    ))}
  </ul>

</article>
