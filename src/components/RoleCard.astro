---
import type { Role } from '../data/profile';

interface Props {
  role: Role;
}

const { role } = Astro.props;
---

<article class="bg-surface border border-border rounded-xl p-6">

  <!-- Title row: role title left, period right -->
  <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
    <h3 class="font-display text-base font-medium text-text">
      {role.title}
    </h3>
    <span class="font-mono text-xs text-muted shrink-0">
      {role.period}
    </span>
  </div>

  <!-- Org · location -->
  <p class="font-mono text-xs lowercase tracking-wide text-muted mt-1">
    {role.org} &middot; {role.location}
  </p>

  <!-- Achievements -->
  <ul class="mt-4 space-y-2">
    {role.achievements.map(a => (
      <li class="flex gap-2.5">
        <span class="mt-[0.3rem] text-accent select-none shrink-0 leading-none" aria-hidden="true">·</span>
        <span class="font-sans text-sm text-text leading-relaxed">{a.text}</span>
      </li>
    ))}
  </ul>

</article>
