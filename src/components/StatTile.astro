---
import type { Stat } from '../data/profile';

interface Props {
  stat: Stat;
}

const { stat } = Astro.props;
---

<div class="bg-surface border border-border rounded-xl p-6 flex flex-col gap-1">
  <span class="font-mono text-3xl sm:text-4xl font-medium text-accent leading-none">
    {stat.value}
  </span>
  <span class="font-mono text-xs lowercase tracking-wide text-muted mt-2">
    {stat.label}
  </span>
  {stat.context && (
    <span class="font-mono text-xs text-muted opacity-60 mt-0.5">
      {stat.context}
    </span>
  )}
</div>
