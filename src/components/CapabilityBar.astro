---
import type { Capability } from '../data/profile';

interface Props {
  capability: Capability;
}

const { capability } = Astro.props;
---

<div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4">
  <span class="font-mono text-xs lowercase tracking-wide text-muted sm:w-52 shrink-0">
    {capability.area}
  </span>
  <div class="flex-1 h-0.5 bg-border relative rounded-full">
    <div
      class="absolute inset-y-0 left-0 bg-accent rounded-full"
      style={`width: ${capability.decorativeWidth}%`}
    />
  </div>
</div>
