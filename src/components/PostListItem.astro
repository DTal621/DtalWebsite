---
interface Props {
  title: string;
  meta: string;        // e.g. "jan 2025" or "mirror · sep 2024"
  url: string;
  summary?: string;
  external?: boolean;  // opens in new tab + shows ↗ indicator
}

const { title, meta, url, summary, external = false } = Astro.props;
---

<li class="group py-5 border-b border-border last:border-b-0">
  <a
    href={url}
    target={external ? '_blank' : undefined}
    rel={external ? 'noopener noreferrer' : undefined}
    class="flex items-start justify-between gap-4"
  >
    <div class="min-w-0">
      <span class="font-sans text-sm font-medium text-text group-hover:text-accent transition-colors leading-snug">
        {title}
      </span>
      <div class="mt-1.5 flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
        <span class="font-mono text-xs lowercase text-muted">{meta}</span>
        {summary && (
          <span class="font-mono text-xs text-muted opacity-70">— {summary}</span>
        )}
      </div>
    </div>
    {external && (
      <span
        class="shrink-0 mt-0.5 font-mono text-xs text-muted group-hover:text-accent transition-colors"
        aria-hidden="true"
      >
        ↗
      </span>
    )}
  </a>
</li>
