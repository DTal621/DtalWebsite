---
interface Props {
  title: string;
  meta: string;        // e.g. "Jan 2025" or "Mirror · Sep 2024"
  url: string;
  summary?: string;
  external?: boolean;  // opens in new tab + shows ↗ indicator
}

const { title, meta, url, summary, external = false } = Astro.props;
---

<li class="group py-5 border-b border-brand-border last:border-b-0">
  <a
    href={url}
    target={external ? '_blank' : undefined}
    rel={external ? 'noopener noreferrer' : undefined}
    class="flex items-start justify-between gap-4"
  >
    <div class="min-w-0">
      <span class="text-sm font-medium text-brand-accent group-hover:underline underline-offset-2 leading-snug">
        {title}
      </span>
      <div class="mt-1 flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
        <span class="text-xs text-brand-muted">{meta}</span>
        {summary && (
          <span class="text-xs text-brand-muted">— {summary}</span>
        )}
      </div>
    </div>
    {external && (
      <span class="shrink-0 mt-0.5 text-brand-muted group-hover:text-brand-accent transition-colors text-sm" aria-hidden="true">
        ↗
      </span>
    )}
  </a>
</li>
