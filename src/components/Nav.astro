---
import { profile } from '../data/profile';

const navLinks = [
  { label: 'home',    href: '/'        },
  { label: 'work',    href: '/work'    },
  { label: 'writing', href: '/writing' },
  { label: 'about',   href: '/about'   },
];

const xLink        = profile.links.find(l => l.label === 'X');
const githubLink   = profile.links.find(l => l.label === 'GitHub');
const linkedinLink = profile.links.find(l => l.label === 'LinkedIn');

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-bg/95 backdrop-blur-sm border-b border-border">
  <nav class="max-w-4xl mx-auto px-4 h-14 flex items-center justify-between gap-4">

    <!-- Wordmark -->
    <a
      href="/"
      class="font-mono text-sm font-medium text-accent tracking-tight shrink-0 hover:opacity-80 transition-opacity"
    >
      {profile.name}
    </a>

    <!-- Page links -->
    <ul class="flex items-center gap-0.5">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'font-mono text-xs tracking-wide px-3 py-1.5 rounded-md transition-colors',
              currentPath === link.href
                ? 'text-accent font-medium'
                : 'text-muted hover:text-text hover:bg-surface',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right side: social icons + theme toggle -->
    <div class="flex items-center gap-1 shrink-0">

      <!-- X -->
      {xLink && (
        <a href={xLink.url} target="_blank" rel="noopener noreferrer"
           aria-label="X (Twitter)"
           class="p-1.5 rounded-md text-muted hover:text-accent hover:bg-surface transition-colors">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.736l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      )}

      <!-- LinkedIn -->
      {linkedinLink && (
        <a href={linkedinLink.url} target="_blank" rel="noopener noreferrer"
           aria-label="LinkedIn"
           class="p-1.5 rounded-md text-muted hover:text-accent hover:bg-surface transition-colors">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      )}

      <!-- GitHub -->
      {githubLink && (
        <a href={githubLink.url} target="_blank" rel="noopener noreferrer"
           aria-label="GitHub"
           class="p-1.5 rounded-md text-muted hover:text-accent hover:bg-surface transition-colors">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
      )}

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="p-1.5 rounded-md text-muted hover:text-accent hover:bg-surface transition-colors"
      >
        <!-- Sun (shown in dark mode) -->
        <svg id="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <!-- Moon (shown in light mode) -->
        <svg id="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>

  </nav>
</header>

<script is:inline>
  (function () {
    function applyTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      var sun  = document.getElementById('icon-sun');
      var moon = document.getElementById('icon-moon');
      if (sun && moon) {
        sun.style.display  = theme === 'dark'  ? 'block' : 'none';
        moon.style.display = theme === 'light' ? 'block' : 'none';
      }
    }

    // Set initial icon state
    var current = document.documentElement.getAttribute('data-theme') || 'light';
    applyTheme(current);

    // Wire toggle button
    var btn = document.getElementById('theme-toggle');
    if (btn) {
      btn.addEventListener('click', function () {
        var next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        applyTheme(next);
      });
    }
  })();
</script>
