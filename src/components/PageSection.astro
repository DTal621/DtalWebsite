---
interface Props {
  heading: string;
  /** Omits the top border — use for the first section on a page */
  first?: boolean;
}

const { heading, first = false } = Astro.props;
---

<section
  class:list={[
    'max-w-4xl mx-auto px-4 py-16',
    !first && 'border-t border-border',
  ]}
>
  <h2 class="font-mono text-xs lowercase tracking-widest text-muted mb-8">
    {heading}
  </h2>
  <slot />
</section>
